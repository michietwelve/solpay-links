generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PaymentLink {
  id              String   @id
  recipientWallet String
  amountLamports  String?
  token           String
  label           String
  description     String
  memo            String?
  expiresAt       DateTime?
  maxPayments     Int?
  paymentCount    Int      @default(0)
  viewCount       Int      @default(0)
  redirectUrl     String?
  digitalAssetUrl String?
  status          String   @default("active")
  createdAt       DateTime @default(now())
  merchantId      String?
  payments        PaymentRecord[]

  // Hackathon Superpowers
  isSplitPayment      Boolean  @default(false)
  targetAmountLamports String? 
  
  isRoundupEnabled    Boolean  @default(false)
  roundupVaultAddress String?
  
  isLootboxEnabled    Boolean  @default(false)
  cashbackBps         Int?     @default(0)
  referralBps         Int?     @default(0)
  discountBps         Int?     @default(0)

  // Tipping Point Group Buy
  tippingPointCount   Int?     @default(0)
  tippingPointAmount  String?
  
  // Escrow
  isEscrowEnabled     Boolean? @default(false)
  
  // Institutional Controls
  maxSlippageBps      Int      @default(50)

  // Umbra Stealth Payments
  isStealthEnabled    Boolean  @default(false)
  stealthAddress      String?  // derived Solana address — where funds actually go
  ephemeralPubkey     String?  // X25519 ephemeral pubkey — embedded in tx memo
}

model WebhookLog {
  id          String   @id @default(cuid())
  merchantId  String
  url         String
  event       String
  payload     String
  status      Int
  success     Boolean
  createdAt   DateTime @default(now())
}

model PaymentRecord {
  id              String   @id
  linkId          String
  payerWallet     String
  amountLamports  String
  token           String
  signature       String?
  status          String   @default("pending")
  escrowStatus    String?  @default("none") // none, locked, released, refunded
  createdAt       DateTime @default(now())
  confirmedAt     DateTime?
  metadata        String?  // JSON blob for compliance & audit
  link            PaymentLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
}

model MerchantProfile {
  merchantId      String   @id
  businessName    String?
  snsDomain       String?
  isPro           Boolean  @default(false)
  logoUrl         String?
  accentColor     String?  @default("#c5a36e")
  webhookUrl      String?
  webhookSecret   String?
  email           String?
  apiKey          String?  @unique
  apiKeyLastUsed  DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Umbra Stealth Identity
  stealthViewPubkey   String?  // X25519 pubkey — published, used for ECDH by senders

  // Loyalty Receipts (cNFTs)
  merkleTree          String?
  collectionMint      String?

  // Infrastructure Preference
  network             String   @default("devnet") // devnet, mainnet
}

model WebhookJob {
  id         String   @id @default(cuid())
  merchantId String
  url        String
  payload    String   // JSON
  secret     String?
  attempts   Int      @default(0)
  nextRunAt  DateTime @default(now())
  status     String   @default("pending") // pending, completed, failed
}
