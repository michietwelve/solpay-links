PORT=3000
RPC_ENDPOINT=https://api.devnet.solana.com
TREASURY_WALLET=<your-treasury-wallet-pubkey>
API_BASE_URL=http://localhost:3000
ICON_URL=https://solpay.link/icon.png
PLATFORM_FEE_BPS=50

# ─── Hosted payment page ──────────────────────────────────────────────────
# Privy app ID — used client-side to embed a wallet in /pay/[linkId]
NEXT_PUBLIC_PRIVY_APP_ID=<your-privy-app-id>

# MoonPay publishable key — used client-side to open the fiat-to-crypto ramp
NEXT_PUBLIC_MOONPAY_API_KEY=<your-moonpay-publishable-key>
